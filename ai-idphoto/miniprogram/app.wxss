page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 30rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #4a6cf7, #6c8cff);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  border: 2rpx solid #4a6cf7;
  color: #4a6cf7;
  background: #fff;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  text-align: center;
}
