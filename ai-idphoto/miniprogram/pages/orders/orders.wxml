<view class="page">
  <view class="header">下载记录</view>

  <view class="empty" wx:if="{{orders.length === 0}}">
    <text class="empty-icon">📷</text>
    <text class="empty-text">还没有下载记录</text>
    <text class="empty-hint">制作你的第一张证件照吧</text>
    <button class="btn-primary" style="margin-top:30rpx" bindtap="onMakePhoto">去制作</button>
  </view>

  <view class="order-list" wx:else>
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <image src="{{item.thumbUrl}}" mode="aspectFill" class="order-thumb" />
      <view class="order-info">
        <text class="order-spec">{{item.specName}} · {{item.colorName}}背景</text>
        <text class="order-time">{{item.time}}</text>
      </view>
      <button class="btn-download" bindtap="onDownload" data-url="{{item.resultUrl}}">下载</button>
      <button class="btn-delete" bindtap="onDelete" data-id="{{item.id}}">×</button>
    </view>
  </view>
</view>
