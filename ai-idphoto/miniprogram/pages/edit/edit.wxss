.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* Preview */
.preview-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #e8e8e8;
  position: relative;
}

.loading-box {
  text-align: center;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #4a6cf7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.preview-img {
  max-width: 100%;
  max-height: 100%;
  border-radius: 8rpx;
}

/* Controls */
.controls {
  background: #fff;
  padding: 24rpx 30rpx;
}

.control-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.control-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  width: 80rpx;
  flex-shrink: 0;
}

.chip-scroll {
  flex: 1;
  white-space: nowrap;
}

.chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
}

.chip.active {
  background: #f0f3ff;
  color: #4a6cf7;
  font-weight: 500;
}

.color-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
}

.color-chip.active {
  background: #f0f3ff;
  color: #4a6cf7;
  font-weight: 500;
}

.mini-swatch {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 1rpx solid #ddd;
  margin-right: 10rpx;
}

/* Footer */
.footer-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.hidden-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 600rpx;
  height: 800rpx;
}

.footer-bar button {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 50rpx;
}

.footer-bar .btn-primary {
  flex: 1.5;
}
