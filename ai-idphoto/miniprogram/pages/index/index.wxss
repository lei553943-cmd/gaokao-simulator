.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 40%, #f5f5f5 40%);
  padding-bottom: 60rpx;
}

.header {
  padding: 40rpx 40rpx 60rpx;
  text-align: center;
  position: relative;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 12rpx;
  display: block;
}

.header-link {
  position: absolute;
  top: 50rpx;
  right: 40rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.header-link:active {
  color: #fff;
}

/* Upload */
.upload-section {
  padding: 0 40rpx;
  margin-top: -20rpx;
}

.upload-box {
  background: #fff;
  border-radius: 24rpx;
  border: 3rpx dashed #d0d5e0;
  padding: 80rpx 0;
  text-align: center;
  transition: all 0.2s;
}

.upload-box:active {
  border-color: #4a6cf7;
  background: #f0f3ff;
}

.upload-icon {
  font-size: 80rpx;
  color: #4a6cf7;
  font-weight: 200;
  line-height: 1;
}

.upload-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-top: 16rpx;
  font-weight: 500;
}

.upload-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* Section */
.section {
  padding: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

/* Specs */
.spec-scroll {
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.spec-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
  padding: 24rpx 10rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
  white-space: normal;
}

.spec-item.active {
  border-color: #4a6cf7;
  background: #f0f3ff;
}

.spec-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.spec-size {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.spec-use {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.spec-check {
  position: absolute;
  top: 0;
  right: 0;
  background: #4a6cf7;
  color: #fff;
  width: 36rpx;
  height: 36rpx;
  border-radius: 0 16rpx 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* Colors */
.color-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.color-item {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 50rpx;
  border: 2rpx solid transparent;
}

.color-item.active {
  border-color: #4a6cf7;
}

.color-swatch {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  margin-right: 12rpx;
}

.color-name {
  font-size: 26rpx;
  color: #333;
}

/* Button */
.btn-area {
  padding: 40rpx;
  text-align: center;
}

.make-btn {
  width: 100%;
  padding: 28rpx 0;
  font-size: 34rpx;
  box-shadow: 0 8rpx 24rpx rgba(74,108,247,0.3);
}

.price-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
