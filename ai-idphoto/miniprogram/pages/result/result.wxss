.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

/* Preview */
.preview-section {
  position: relative;
  background: #1a1a2e;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 500rpx;
}

.preview-img {
  max-width: 100%;
  max-height: 500rpx;
  border-radius: 8rpx;
}

.watermark {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.watermark text {
  font-size: 60rpx;
  color: rgba(255,255,255,0.35);
  transform: rotate(-30deg);
  letter-spacing: 20rpx;
}

/* Info */
.info-card {
  margin: -20rpx 30rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  position: relative;
  z-index: 1;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* Ad Card */
.ad-card {
  margin: 0 30rpx;
  background: linear-gradient(135deg, #fff6e5, #fffaf0);
  border: 2rpx solid #f0c060;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  position: relative;
}

.ad-badge {
  position: absolute;
  top: -1rpx;
  right: 40rpx;
  background: #f0c060;
  color: #fff;
  font-size: 24rpx;
  padding: 4rpx 24rpx;
  border-radius: 0 0 14rpx 14rpx;
  font-weight: 600;
}

.ad-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #b8860b;
  margin-bottom: 24rpx;
  margin-top: 10rpx;
}

.ad-features {
  text-align: left;
  margin-bottom: 32rpx;
}

.ad-features text {
  display: block;
  font-size: 26rpx;
  line-height: 1.8;
  color: #886a30;
}

.btn-ad {
  background: linear-gradient(135deg, #f0c060, #e8a830);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 600;
  width: 100%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(240,192,96,0.3);
}

.btn-ad:active {
  opacity: 0.85;
}

.play-icon {
  font-size: 28rpx;
}

/* Download Section */
.download-section {
  margin: 30rpx;
  text-align: center;
}

.unlock-badge {
  display: inline-block;
  background: #e8f5e9;
  color: #4caf50;
  font-size: 26rpx;
  padding: 8rpx 32rpx;
  border-radius: 50rpx;
  margin-bottom: 24rpx;
  font-weight: 500;
}

/* Skip ad */
.skip-ad {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 20rpx;
}

.skip-ad:active {
  color: #888;
}
